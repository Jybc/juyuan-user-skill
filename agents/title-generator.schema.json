{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "num_iid": {
            "type": "string",
            "description": "淘宝商品 ID"
          },
          "generated_title": {
            "type": "string",
            "description": "生成的新标题",
            "maxLength": 60
          },
          "scene": {
            "type": "string",
            "description": "穿着场景",
            "enum": ["通勤", "约会", "度假", "日常", "潮酷"]
          },
          "scene_source": {
            "type": "string",
            "description": "场景判断来源",
            "enum": ["user", "attr_infer", "price_infer", "image_infer", "default"]
          },
          "keywords_preserved": {
            "type": "boolean",
            "description": "原关键词是否全部保留"
          },
          "reasoning": {
            "type": "object",
            "properties": {
              "scene": { "type": "string" },
              "buyer": { "type": "string" },
              "keywords": { "type": "string" },
              "edge": { "type": "string" }
            },
            "required": ["scene", "buyer", "keywords", "edge"]
          },
          "length": {
            "type": "integer",
            "minimum": 5,
            "maximum": 30
          },
          "quality_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": ["num_iid", "generated_title", "scene", "scene_source", "keywords_preserved", "reasoning", "quality_score"]
      }
    }
  },
  "required": ["results"]
}
